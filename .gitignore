.env
.env.production
node_modules/
venv/
__pycache__/
reports/
alembic/versions/__pycache__/
.claude/
!.claude/commands/

# Data room contents (raw source files + derived chunks/index/analytics).
# Confidential and large — synced to prod separately via scripts/sync-data.ps1.
# registry.json is server-local state (doc_ids are UUIDs generated per-ingest,
# not portable across machines). Server is authoritative owner — never tracked.
# See session 24 Tier 1.2 + session 26 deploy-collision root cause.
data/*/dataroom/*

# Post-ingest hooks ARE deployment infrastructure (authored bash scripts that
# auto-process newly-ingested files), not per-machine state. Re-include them
# so they ship to prod via git pull. Same-bytes scp from sync-data.ps1 is
# idempotent overwrite — no dual-rail collision risk.
!data/*/dataroom/.post-ingest.sh

# Agent session state (regenerated at runtime, per-machine)
data/_agent_sessions/

# Mind stores — Master Mind (data/_master_mind/*.jsonl) holds shared
# institutional knowledge with no per-machine UUIDs; TRACKED in git so every
# machine converges on the same Framework codification candidates, IC norms,
# preferences, and writing style. Per-company mind dirs hold UUIDs referenced
# by relations.json and mutate under the event bus — per-machine, gitignored.
# If a per-machine subdir ever lands under _master_mind/, add a specific rule
# for that path here rather than re-ignoring the whole directory.
**/mind/*.jsonl
**/mind/consolidated.json
**/mind/style_guide.md
**/mind/profile.json
# Investment thesis — per-machine (pillar IDs are per-seed UUIDs; `last_value`
# and `last_checked` mutate on every drift check). Re-create on a fresh
# machine via `scripts/seed_{company}_thesis.py`.
**/mind/thesis.json

# Asset Class Mind — semantic asset-class jsonl files. Seeded by
# scripts/seed_asset_class_mind.py on each machine; analyst-approved
# entries accumulate via the pending-review queue. Server is authoritative
# owner (same pattern as _master_mind above).
data/_asset_class_mind/

# External Intelligence pending-review queue — analyst-gated staging area
# for web_search and other external findings. Per-machine until approved.
data/_pending_review/

# Startup dependency probe output (regenerated every app boot)
data/_platform_health.json

# Per-product covenant evaluation history — the backend appends to this file
# every /portfolio/covenants call, so laptop and prod diverge immediately. Each
# machine keeps its own local history. Audit-trail; not source state. Session
# 31 EoD caught this after a runtime-state commit collided with prod's live
# writes during the redeploy pull.
data/*/*/covenant_history.json

# Intelligence System relation graph — written by the event bus listeners on
# every TAPE_INGESTED / DOCUMENT_INGESTED / MEMO_EDITED. Diverges per machine
# the same way the mind jsonl files do.
**/mind/relations.json
