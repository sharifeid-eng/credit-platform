.env
.env.production
node_modules/
venv/
__pycache__/
reports/
alembic/versions/__pycache__/
.claude/
!.claude/commands/

# Data room contents (raw source files + derived chunks/index/analytics).
# Confidential and large — synced to prod separately via scripts/sync-data.ps1.
# EXCEPT: registry.json — lightweight catalog, IS tracked so re-ingest is idempotent.
data/*/dataroom/*
!data/*/dataroom/registry.json

# Agent session state (regenerated at runtime, per-machine)
data/_agent_sessions/

# Living Mind JSONL files (accumulate over time, machine-specific)
data/_master_mind/
**/mind/*.jsonl
**/mind/consolidated.json
**/mind/style_guide.md
**/mind/profile.json
