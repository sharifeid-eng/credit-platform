.env
.env.production
node_modules/
venv/
__pycache__/
reports/
alembic/versions/__pycache__/
.claude/
!.claude/commands/

# Data room contents (raw source files + derived chunks/index/analytics).
# Confidential and large — synced to prod separately via scripts/sync-data.ps1.
# registry.json is server-local state (doc_ids are UUIDs generated per-ingest,
# not portable across machines). Server is authoritative owner — never tracked.
# See session 24 Tier 1.2 + session 26 deploy-collision root cause.
data/*/dataroom/*

# Agent session state (regenerated at runtime, per-machine)
data/_agent_sessions/

# Living Mind JSONL files (accumulate over time, machine-specific)
data/_master_mind/
**/mind/*.jsonl
**/mind/consolidated.json
**/mind/style_guide.md
**/mind/profile.json

# Asset Class Mind — semantic asset-class jsonl files. Seeded by
# scripts/seed_asset_class_mind.py on each machine; analyst-approved
# entries accumulate via the pending-review queue. Server is authoritative
# owner (same pattern as _master_mind above).
data/_asset_class_mind/

# External Intelligence pending-review queue — analyst-gated staging area
# for web_search and other external findings. Per-machine until approved.
data/_pending_review/

# Startup dependency probe output (regenerated every app boot)
data/_platform_health.json
