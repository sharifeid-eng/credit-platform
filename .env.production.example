# Laith Production Environment
# Copy this to .env.production and fill in real values
# NEVER commit .env.production to git

# Anthropic API key (required for AI features)
ANTHROPIC_API_KEY=sk-ant-...

# PostgreSQL password (used by both backend and db containers)
POSTGRES_PASSWORD=change-me-to-a-strong-password

# Domain (used for CORS — update if your domain differs)
CORS_ORIGINS=https://laithanalytics.ai,https://www.laithanalytics.ai

# Cloudflare Access authentication (required for user auth in production)
# Team name from your Cloudflare Zero Trust dashboard
CF_TEAM=amwalcp
# Application Audience (AUD) tag — find in Access > Applications > your app > Overview
CF_APP_AUD=your-application-audience-tag
# Email of the first admin user (auto-provisioned on first startup)
ADMIN_EMAIL=sharif@example.com

# Agent configuration (optional — sensible defaults used if not set)
# AGENT_DEFAULT_MODEL=claude-opus-4-6
# AGENT_SONNET_MODEL=claude-sonnet-4-6
# AGENT_SESSION_EXPIRY_HOURS=24
# AGENT_MAX_SESSIONS_PER_USER=20
# AGENT_MAX_TOKENS_PER_DAY=500000

# ── Hybrid memo pipeline — model tier overrides (optional) ──
# All AI calls on the platform route through core.ai_client, which resolves
# each tier to an actual model ID. Override any tier globally via env var.
# Defaults fall back through the chain if the preferred model isn't available.
#
#   auto       → trivial templated content (appendix)
#   structured → analytics / data-room sections
#   research   → short-burst agent research packs
#   judgment   → exec summary, thesis, recommendation, legal risk assessment
#   polish     → final whole-memo coherence pass
#
# LAITH_MODEL_AUTO=claude-haiku-4-5
# LAITH_MODEL_STRUCTURED=claude-sonnet-4-6
# LAITH_MODEL_RESEARCH=claude-sonnet-4-6
# LAITH_MODEL_JUDGMENT=claude-opus-4-7
# LAITH_MODEL_POLISH=claude-opus-4-7
#
# Retry behaviour (SDK exponential backoff on 429/529/503)
# LAITH_AI_MAX_RETRIES=3
#
# Parallel section fan-out cap during stage 2 (lower = safer on ITPM caps)
# LAITH_PARALLEL_SECTIONS=3
